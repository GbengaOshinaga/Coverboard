generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  MEMBER
}

enum MemberType {
  EMPLOYEE
  CONTRACTOR
  FREELANCER
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  VARIABLE_HOURS
}

enum LeaveCategory {
  PAID
  UNPAID
  STATUTORY
}

enum BankHolidayRegion {
  ENGLAND_WALES
  SCOTLAND
  NORTHERN_IRELAND
}

enum DataResidency {
  UK
  EU
  US
}

enum SubscriptionPlan {
  STARTER
  GROWTH
  SCALE
  PRO
}

model Organization {
  id                  String   @id @default(cuid())
  name                String
  slug                String   @unique
  onboardingCompleted Boolean  @default(false)
  ukBankHolidayInclusive Boolean @default(true)
  ukBankHolidayRegion    BankHolidayRegion @default(ENGLAND_WALES)
  ukCarryOverEnabled     Boolean @default(false)
  ukCarryOverMax         Int @default(0)
  ukCarryOverExpiryMonth Int @default(3)
  ukCarryOverExpiryDay   Int @default(31)
  dataResidency          DataResidency @default(EU)
  maxAdminUsers          Int @default(2)
  plan                   SubscriptionPlan @default(STARTER)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  users            User[]
  leaveTypes       LeaveType[]
  publicHolidays   PublicHoliday[]
  bankHolidays     BankHoliday[]
  jiraIntegration  JiraIntegration?
  jiraUserMappings JiraUserMapping[]
}

model User {
  id             String     @id @default(cuid())
  email          String     @unique
  name           String
  passwordHash   String
  role           Role       @default(MEMBER)
  memberType     MemberType @default(EMPLOYEE)
  employmentType EmploymentType @default(FULL_TIME)
  daysWorkedPerWeek Float @default(5)
  fteRatio       Float @default(1)
  qualifyingDaysPerWeek Int @default(5)
  averageWeeklyEarnings Decimal? @db.Decimal(8, 2)
  countryCode    String     @default("NG")
  rightToWorkVerified Boolean?
  department     String?
  serviceStartDate DateTime?
  ukParentalLeaveChildCount Int @default(0)
  digestOptOut   Boolean    @default(false)
  organizationId String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leaveRequests       LeaveRequest[]       @relation("UserLeaveRequests")
  reviewedLeaves      LeaveRequest[]       @relation("ReviewerLeaveRequests")
  passwordResetTokens PasswordResetToken[]
  jiraUserMapping     JiraUserMapping?
  jiraConnections     JiraIntegration[]    @relation("JiraConnectedBy")
  weeklyHours         UserWeeklyHours[]
  carryOverBalances   LeaveCarryOverBalance[]
  weeklyEarnings      WeeklyEarning[]
}

model LeaveType {
  id             String   @id @default(cuid())
  name           String
  color          String
  isPaid         Boolean  @default(true)
  category       LeaveCategory @default(PAID)
  defaultDays    Int
  requiresEvidence Boolean @default(false)
  minNoticeDays  Int @default(0)
  durationLogic  String?
  countryCode    String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leaveRequests LeaveRequest[]
  leavePolicies LeavePolicy[]
  carryOverBalances LeaveCarryOverBalance[]

  @@unique([name, organizationId])
}

model LeavePolicy {
  id              String   @id @default(cuid())
  countryCode     String
  annualAllowance Int
  carryOverMax    Int      @default(0)
  leaveTypeId     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@unique([countryCode, leaveTypeId])
}

model LeaveRequest {
  id           String      @id @default(cuid())
  startDate    DateTime
  endDate      DateTime
  status       LeaveStatus @default(PENDING)
  note         String?
  userId       String
  leaveTypeId  String
  reviewedById String?
  reviewedAt   DateTime?
  evidenceProvided Boolean @default(false)
  kitDaysUsed Int @default(0)
  dailyHolidayPayRate Decimal? @db.Decimal(10, 2)
  sspDaysPaid Int @default(0)
  sspLimitReached Boolean @default(false)
  smpAverageWeeklyEarnings Decimal? @db.Decimal(8, 2)
  smpPhase1EndDate DateTime? @db.Date
  smpPhase2EndDate DateTime? @db.Date
  smpPhase1WeeklyRate Decimal? @db.Decimal(8, 2)
  smpPhase2WeeklyRate Decimal? @db.Decimal(8, 2)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  user       User      @relation("UserLeaveRequests", fields: [userId], references: [id], onDelete: Cascade)
  leaveType  LeaveType @relation(fields: [leaveTypeId], references: [id])
  reviewedBy User?     @relation("ReviewerLeaveRequests", fields: [reviewedById], references: [id])
}

model JiraIntegration {
  id              String   @id @default(cuid())
  cloudId         String
  siteUrl         String
  accessToken     String
  refreshToken    String
  tokenExpiresAt  DateTime
  organizationId  String   @unique
  connectedByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  connectedBy  User         @relation("JiraConnectedBy", fields: [connectedByUserId], references: [id])
}

model JiraUserMapping {
  id             String @id @default(cuid())
  jiraAccountId  String
  jiraEmail      String
  userId         String   @unique
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PublicHoliday {
  id             String   @id @default(cuid())
  name           String
  date           DateTime
  countryCode    String
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([date, countryCode, organizationId])
}

model BankHoliday {
  id             String   @id @default(cuid())
  name           String
  date           DateTime
  region         BankHolidayRegion
  countryCode    String   @default("GB")
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([date, region, organizationId])
}

model UserWeeklyHours {
  id           String   @id @default(cuid())
  userId       String
  weekStartDate DateTime
  hoursWorked  Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStartDate])
}

model LeaveCarryOverBalance {
  id           String   @id @default(cuid())
  userId       String
  leaveTypeId  String
  leaveYear    Int
  daysCarried  Float
  daysRemaining Float
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@unique([userId, leaveTypeId, leaveYear])
}

model WeeklyEarning {
  id             String   @id @default(cuid())
  userId         String
  weekStartDate  DateTime @db.Date
  grossEarnings  Decimal  @db.Decimal(10, 2)
  hoursWorked    Decimal  @db.Decimal(6, 2)
  isZeroPayWeek  Boolean  @default(false)
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStartDate])
  @@index([userId, weekStartDate])
}

model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  actorId        String?
  actorEmail     String?
  actorRole      String?
  action         String
  resource       String
  resourceId     String?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  @@index([organizationId, createdAt])
  @@index([organizationId, action])
  @@index([organizationId, resource])
}
