# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/coverboard?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-random-secret"

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# Cron — REQUIRED in production. The /api/cron/weekly-digest and
# /api/cron/process-deletions endpoints refuse to run in production when
# CRON_SECRET is unset (since process-deletions permanently destroys data,
# an open endpoint would be catastrophic). Vercel will inject this header on
# its cron invocations when the env var is set. Optional in local dev.
# CRON_SECRET="a-random-secret"

# Rate limiting — REQUIRED in production. Backs the rate limiter on
# /api/auth/signup, /api/auth/forgot-password, /api/auth/reset-password and
# the NextAuth login flow. When these are missing in production the auth
# routes return 503 (fail closed) so the Privacy Policy's "rate limiting on
# authentication endpoints" claim stays accurate. Optional in local dev.
# Create a free Redis database at https://console.upstash.com — copy the
# REST URL and REST TOKEN from the database details page.
# UPSTASH_REDIS_REST_URL="https://your-db.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="..."

# Email (optional — enables invite emails and leave notifications)
# Sign up at https://resend.com (free: 3,000 emails/month)
# RESEND_API_KEY="re_..."
# EMAIL_FROM="Coverboard <noreply@yourdomain.com>"

# Jira Cloud (optional — enables project coverage warnings)
# Create an OAuth 2.0 (3LO) app at https://developer.atlassian.com/console/myapps/
# Console scopes: read:jira-work, write:jira-work, read:jira-user, read:me
# offline_access is added to the authorize URL by the app (not a console checkbox)
# JIRA_CLIENT_ID=""
# JIRA_CLIENT_SECRET=""
# JIRA_REDIRECT_URI="http://localhost:3000/api/jira/callback"

# Slack (optional — each org connects their workspace from Settings)
# Create one Slack app at https://api.slack.com/apps for your Coverboard product.
# Bot token scopes: commands, chat:write, users:read, users:read.email
# OAuth redirect: https://your-domain/api/slack/callback
# Slash commands + interactivity URLs point at your-domain/api/slack/commands and .../interactions
# SLACK_CLIENT_ID=""
# SLACK_CLIENT_SECRET=""
# SLACK_SIGNING_SECRET=""
# SLACK_REDIRECT_URI="http://localhost:3000/api/slack/callback"
# SLACK_NOTIFICATION_CHANNEL="#time-off"

# UK statutory rates (optional overrides; defaults are in code)
# Update each April via HMRC guidance.
# UK statutory rates — defaults below are 2026/27 (effective 6 April 2026).
# Whoever runs payroll must refresh these each April. Step-by-step procedure
# and HMRC source links: docs/april-statutory-rate-update.md.
# SSP_WEEKLY_RATE="123.25"   # Statutory Sick Pay weekly rate (2026/27)
# SMP_WEEKLY_RATE="194.32"   # Statutory Maternity Pay flat weekly rate (2026/27)
# SMP_FLAT_RATE="194.32"     # Alias of SMP_WEEKLY_RATE used by the SMP phase calculator
# LEL_WEEKLY="125"           # Lower Earnings Limit — SSP eligibility floor (2026/27, held from 2025/26)

# Help & Contact page (optional — defaults shown in src/app/(dashboard)/help/page.tsx)
# NEXT_PUBLIC_SUPPORT_EMAIL="support@coverboard.io"
# NEXT_PUBLIC_PRIORITY_SUPPORT_EMAIL="priority@coverboard.io"
# NEXT_PUBLIC_SLA_SUPPORT_EMAIL="pro@coverboard.io"

# Founder outreach (optional — one-off welcome email from the founder to the
# first N verified admin signups; see src/lib/founder-outreach.ts)
# Set FOUNDER_OUTREACH_CAP=0 on staging/preview so test signups don't burn slots.
# FOUNDER_OUTREACH_CAP="100"
# FOUNDER_FROM="Coverboard Founder <hello@coverboard.io>"
# FOUNDER_REPLY_TO="hello@coverboard.io"
# FOUNDER_NAME="Gbenga"

# Observability (optional — recommended for production)
# Sentry: https://sentry.io — errors & performance
# NEXT_PUBLIC_SENTRY_DSN="https://...@....ingest.sentry.io/..."
# SENTRY_ORG=""          # optional — upload source maps in CI
# SENTRY_PROJECT=""
# PostHog EU: https://eu.posthog.com — product analytics (no PII in events)
# NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN="phc_..."
# NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"

# Stripe (required in production for billing)
# Get these from https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Price IDs for the paid tiers (Stripe Dashboard → Products). FREE has no price.
# STRIPE_PRICE_STARTER="price_..."
# STRIPE_PRICE_GROWTH="price_..."
# STRIPE_PRICE_SCALE="price_..."
# STRIPE_PRICE_PRO="price_..."
