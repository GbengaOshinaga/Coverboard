# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/coverboard?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-random-secret"

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# Cron (optional — secures the weekly digest endpoint)
# CRON_SECRET="a-random-secret"

# Email (optional — enables invite emails and leave notifications)
# Sign up at https://resend.com (free: 3,000 emails/month)
# RESEND_API_KEY="re_..."
# EMAIL_FROM="Coverboard <noreply@yourdomain.com>"

# Jira Cloud (optional — enables project coverage warnings)
# Create an OAuth 2.0 (3LO) app at https://developer.atlassian.com/console/myapps/
# Scopes: read:jira-work, write:jira-work, read:jira-user, read:me, offline_access
# JIRA_CLIENT_ID=""
# JIRA_CLIENT_SECRET=""
# JIRA_REDIRECT_URI="http://localhost:3000/api/jira/callback"

# Slack Bot (optional — enables /whosout, /requestleave, /mybalance)
# Create a Slack app at https://api.slack.com/apps
# Bot token scopes: commands, chat:write, users:read, users:read.email
# SLACK_BOT_TOKEN="xoxb-..."
# SLACK_SIGNING_SECRET="..."
# SLACK_NOTIFICATION_CHANNEL="#time-off"

# UK statutory rates (optional overrides; defaults are in code)
# Update each April via HMRC guidance.
# SSP_WEEKLY_RATE="123.25"   # Statutory Sick Pay weekly rate (2026/27)
# SMP_WEEKLY_RATE="194.32"   # Statutory Maternity Pay flat weekly rate (2026/27)
# SMP_FLAT_RATE="194.32"     # Alias of SMP_WEEKLY_RATE used by the SMP phase calculator
# LEL_WEEKLY="123"           # Lower Earnings Limit — SSP eligibility floor (2024/25)

# Help & Contact page (optional — defaults shown in src/app/(dashboard)/help/page.tsx)
# NEXT_PUBLIC_SUPPORT_EMAIL="hello@coverboard.app"
# NEXT_PUBLIC_PRIORITY_SUPPORT_EMAIL="priority@coverboard.app"
# NEXT_PUBLIC_SLA_SUPPORT_EMAIL="pro@coverboard.app"

# Landing: Pro tier "Book a demo" CTA (optional)
# NEXT_PUBLIC_DEMO_BOOKING_URL="https://cal.com/coverboard/demo"

# Stripe (required in production for billing)
# Get these from https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_PUBLISHABLE_KEY="pk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
